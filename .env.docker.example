# ──────────────────────────────────────────────────────────
# Titan-IBKR Docker Compose — credentials & runtime config
# ──────────────────────────────────────────────────────────
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# Then bring up the stack:
#   docker compose --env-file .env.docker up -d --build
#
# This file is consumed ONLY by docker-compose.yml. The host-Python
# workflow keeps using .env (see .env.example).
# ──────────────────────────────────────────────────────────

# ── IB Gateway login (gnzsnz/ib-gateway image) ───────────
# Use your IBKR PAPER credentials. Live credentials require 2FA on every
# weekly restart and are out of scope for this paper-trading stack.
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password

# Trading mode: paper | live
TRADING_MODE=paper

# ── Strategy connection (titan-portfolio container) ──────
# IBKR_HOST is hardcoded to "ib-gateway" in docker-compose.yml -- do not
# override it here. Compose DNS routes it to the gateway container.

# Port the strategy connects to on the ib-gateway container.
# The gnzsnz/ib-gateway image runs the actual Gateway on 4001 (live) /
# 4002 (paper) internally, and forwards them via socat to 4003 (live) /
# 4004 (paper) for external clients — that's what we connect to.
#   Paper: 4004     Live: 4003
IBKR_PORT=4004

# Client ID for the strategy connection. Avoid 1 (default), 0, 20 (ORB),
# 25 (test), 98 (kill_switch), 99 (balance).
IBKR_CLIENT_ID=7

# Your IBKR paper account ID — required by run_portfolio.py at startup.
# Paper accounts are formatted DUxxxxxxx; live accounts Uxxxxxxx.
IBKR_ACCOUNT_ID=DUxxxxxxx

# ── Optional integrations ────────────────────────────────
# Databento: only needed if you re-run download_data_databento.py from
# inside the container. Strategy runtime does not need it.
DATABENTO_API_KEY=

# Slack webhook for guardian / halt alerts. Leave blank to disable.
SLACK_WEBHOOK_URL=

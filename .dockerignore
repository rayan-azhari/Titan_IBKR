# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtualenvs (we install into the image, not from host)
.venv/
venv/

# VCS
.git/
.gitignore
.gitattributes

# Local runtime state — runtime mounts a named volume for this
.tmp/

# Image archives produced by scripts/build_image.sh — never bake them
# back into the build context (would create circular bloat)
dist/

# Data and models — bind-mounted at runtime, don't bake several GB into image
data/
models/

# Tests, notebooks — never run in production container
tests/
notebooks/
*.ipynb

# research/ IS included in the production image because the V2.0 GEM
# live class delegates to the research function gem_target_weights /
# gem_returns (parity-by-construction per V3.6 A10). Keep research/__init__.py
# + research/gem/ at minimum; other research subpackages (ic_analysis,
# samir_stack, etc.) are included for transitive imports but not invoked.

# Docs / runbooks — operators read these on the host, not in-container
directives/
docs/
README.md
*.md

# Secrets and local env files
.env
.env.docker
.env.local
.env.*.local

# IDE / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db

# Plans / project memory
plans/
.claude/

# Compose / docker artifacts (don't recursively include themselves)
docker-compose*.yml
Dockerfile*
.dockerignore

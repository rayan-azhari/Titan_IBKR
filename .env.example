# ──────────────────────────────────────────────────────────
# IBKR TWS/Gateway Credentials
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the interactive setup:
#   uv run python execution/setup_env.py
# ──────────────────────────────────────────────────────────

# TWS/Gateway connection settings
IBKR_HOST=127.0.0.1
IBKR_PORT=4002  # Use 4002 for IB Gateway Paper, 7497 for TWS Paper
IBKR_CLIENT_ID=1

# Your IBKR Paper Account ID (e.g., DU1234567)
IBKR_ACCOUNT_ID=DUxxxxxxx

# ──────────────────────────────────────────────────────────
# Databento (Historical Market Data)
# ──────────────────────────────────────────────────────────
# API key from https://databento.com/portal/keys
DATABENTO_API_KEY=db-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────
# Slack Notifications (Guardian Agent) — Optional
# ──────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
